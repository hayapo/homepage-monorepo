{
  "$schema": "https://v2-8-20.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "preview": {
      "dependsOn": ["^build"], // ^ で依存パッケージのbuildも実行
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "biome:check": {
      "dependsOn": ["^biome:check"]
    },
    "biome:fix": {
      "dependsOn": ["^biome:fix"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
