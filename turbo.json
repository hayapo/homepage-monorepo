{
	"$schema": "https://turborepo.com/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"biome:check": {
			"dependsOn": ["^biome:check"]
		},
		"biome:fix": {
			"dependsOn": ["^biome:fix"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
